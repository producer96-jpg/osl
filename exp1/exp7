#include <iostream>
#include <unistd.h>
#include <sys/resource.h>

using namespace std;

int main()
{
    int priority;

    // Get process ID
    cout << "PID: " << getpid() << endl;

    // Get priority
    priority = getpriority(PRIO_PROCESS, 0);

    cout << "Current Priority: " << priority << endl;

    // Set new priority
    setpriority(PRIO_PROCESS, 0, 5);

    cout << "Priority Changed" << endl;

    return 0;
}

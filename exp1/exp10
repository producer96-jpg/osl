#include <iostream>
#include <cstdlib>   // malloc(), free()

using namespace std;

int main()
{
    int *ptr;

    // Allocate memory
    ptr = (int*) malloc(5 * sizeof(int));

    if (ptr == NULL)
    {
        cout << "Memory Allocation Failed" << endl;
        return 1;
    }

    // Store values
    for (int i = 0; i < 5; i++)
    {
        ptr[i] = i * 10;
    }

    // Display values
    cout << "Stored Values:" << endl;

    for (int i = 0; i < 5; i++)
    {
        cout << ptr[i] << " ";
    }

    cout << endl;

    // Free memory
    free(ptr);

    cout << "Memory Freed" << endl;

    return 0;
}

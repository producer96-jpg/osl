#include <iostream>
#include <cstdlib>  // exit(), abort()

using namespace std;

int main()
{
    int choice;

    cout << "Enter 1 to Exit, 2 to Abort: ";
    cin >> choice;

    if (choice == 1)
    {
        cout << "Process ended normally" << endl;

        // Normal termination
        exit(0);
    }
    else
    {
        cout << "Process aborted abnormally" << endl;

        // Abnormal termination
        abort();
    }

    cout << "This line will not execute" << endl;

    return 0;
}

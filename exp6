#include <iostream> //used for input / output
using namespace std;  //to avoid writing std:: again and again

// ================= FIRST FIT =================
void firstFit(int blockSize[], int m, int processSize[], int n)
{
    int allocation[n]; // array to store which block is assigned to each process

    // initialize all processes as not allocated (-1 means not allocated)
    for(int i = 0; i < n; i++)
        allocation[i] = -1;

    // loop for each process
    for(int i = 0; i < n; i++)
    {
        // check each memory block from beginning
        for(int j = 0; j < m; j++)
        {
            //if block size is enough for process	
            if(blockSize[j] >= processSize[i])
            {
                allocation[i] = j;  //assign block number to process
                blockSize[j] -= processSize[i];  //reduce available memory
                break;  //stop searching after allocation
            }
        }
    }
    //print result
    cout << "\nFirst Fit Allocation: \n";
    for(int i = 0; i < n; i++)
    {
        if(allocation[i] != -1) //if allocated
            cout<<"Process "<<i+1<<" -> Block " <<allocation[i]+1 ;
        else
            cout << "Process "<<i+1<< " -> Not Allocated";
        cout << endl;
    }
}

// ================= BEST FIT =================
void bestFit(int blockSize[], int m, int processSize[], int n)
{
    int allocation[n]; // store allocation

    // initialize all as not allocated
    for(int i = 0; i < n; i++)
        allocation[i] = -1;

    // loop for each process
    for(int i = 0; i < n; i++)
    {
        int bestIndex = -1;   // store smallest suitable block index

        // check all blocks
        for(int j = 0; j < m; j++)
        {
            //if block can fit process
            if(blockSize[j] >= processSize[i])
            {
                //choose smallest block among available ones
                if(bestIndex == -1 || blockSize[j] < blockSize[bestIndex])
                    bestIndex = j;
            }
        }

        // if suitable block found
        if(bestIndex != -1)
        {
            allocation[i] = bestIndex;  //assign block
            blockSize[bestIndex] -= processSize[i];  //reduce size
        }
    }
    //print result
    cout << "\nBest Fit Allocation:\n";
    for(int i = 0; i < n; i++)
    {
        if(allocation[i] != -1)
            cout<<"Process "<<i+1<<" -> Block " <<allocation[i]+1 << endl;
        else
            cout<<"Process "<<i+1<<" -> Not Allocated\n";
    }
}

// ================= WORST FIT =================
void worstFit(int blockSize[], int m, int processSize[], int n)
{
    int allocation[n]; // store allocation

    // initialize
    for(int i = 0; i < n; i++)
        allocation[i] = -1;

    // loop through each process
    for(int i = 0; i < n; i++)
    {
        int worstIndex = -1; // store largest block index

        // check all blocks
        for(int j = 0; j < m; j++)
        {
        	//if block can fit process
            if(blockSize[j] >= processSize[i])
            {
            	//choose largest block
                if(worstIndex == -1 || blockSize[j] > blockSize[worstIndex])
                    worstIndex = j;
            }
        }

        // if block found
        if(worstIndex != -1)
        {
            allocation[i] = worstIndex;  //assign block
            blockSize[worstIndex] -= processSize[i];  //reduce size
        }
    }
	//print result
    cout <<"\nWorst Fit Allocation: \n";
    for(int i = 0; i < n; i++)
    {
        if(allocation[i] != -1)
            cout<<"Process "<<i+1<<" -> Block " <<allocation[i]+1 << endl;
        else
            cout<<"Process "<<i+1<<" -> Not Allocated\n";
    }
}

// ================= MAIN FUNCTION =================
int main()
{
	//define memory blocks for each algorithm separately
    int block1[] = {100, 500, 200, 300, 600};   //for first fit
    int block2[] = {100, 500, 200, 300, 600};   //for best fit  
	int block3[] = {100, 500, 200, 300, 600};   //for worst fit
    
    //define process sizes
    int processSize[] = {212, 417, 112, 426};
    
	int m=5;   //number of memory blocks
	int n=4;   //number of processes
	
	//call each algorithm function
    firstFit(block1, m, processSize, n);
    bestFit(block2, m, processSize, n);
    worstFit(block3, m, processSize, n);

    return 0;  //end program
}

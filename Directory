mkdir("MyDirectory", 0777);

cout << "Directory created.\n";


chdir("MyDirectory");

cout << "Changed to MyDirectory.\n";


char path[100];


getcwd(path, sizeof(path));

cout << "Current Directory Path: <<<< path <<< endl;

chdir("..");

DIR *dir;
struct dirent *entry;
dir opendir(".");
